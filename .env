# Deployment mode: "development" | "production"
# Set to "production" before any public deployment.
ENVIRONMENT=development

# Database (PostgreSQL Asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/onfood

# JWT Authentication
# ROTATE THIS before any public deployment.
# Generate a new secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=db76a8e5377b1e32e9a9c4f12e0bc101ccc5e62aa0b2c62b471048ad5c994e66
JWT_ISSUER=onfood

# OTP hashing — keep separate from JWT_SECRET so rotating one doesn't affect the other.
OTP_HASH_SECRET=751f70bcc30530de8ea5478f7396094227778ed8c7d6755247925ad86a6245b1

# WhatsApp bot
WHATSAPP_BOT_INTERNAL_KEY=Ops8/W9e+TsawpG2ddWqkt+SvV/IXLNTwAV066nziVY=
WHATSAPP_BOT_URL=http://127.0.0.1:3000

# CORS — list of allowed browser origins.
CORS_ALLOWED_ORIGINS=["https://piezometric-lissomely-clarine.ngrok-free.dev"]

# Trusted reverse proxy IPs (for X-Forwarded-For header trust).
# Set to ["127.0.0.1"] when running behind ngrok on the same machine.
TRUSTED_PROXY_IPS=["127.0.0.1"]

# App client identity guard (enforces X-App-Key header on all endpoints)
APP_CLIENT_KEY=ONFOOD_SECURE_CLIENT_APP_KEY_2026
APP_CLIENT_KEY_HEADER=X-App-Key
